rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /smes/{userId} {
      allow create: if signedIn() && request.auth.uid == userId;
      allow read, update: if signedIn() && request.auth.uid == userId;

      // Admins can read all SME records and update status.
      allow read: if isAdmin();
      allow update: if isAdmin() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(["status", "updatedAt"]);
    }

    match /users/{userId} {
      // Only admins manage roles.
      allow read, write: if isAdmin();
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

